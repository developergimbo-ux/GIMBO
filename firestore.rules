rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────────────────────────────────
    function isOwner()  { return request.auth != null && request.auth.token.email.matches("owner[0-9]+@gmail\\.com"); }
    function isMember() { return request.auth != null && request.auth.token.email.matches("member[0-9]+@gmail\\.com"); }
    function isZumba()  { return request.auth != null && request.auth.token.email.matches("zumba[0-9]+@gmail\\.com"); }
    function isLoggedIn() { return request.auth != null; }

    // ─── GYM COLLECTIONS ────────────────────────────────────────
    match /members/{docId} {
      allow read: if isOwner() || (isMember() && request.auth.token.email == resource.data.email);
      allow write: if isOwner();
    }

    match /attendance/{docId} {
      allow read: if isOwner() || isMember();
      allow write: if isOwner();
    }

    match /fees/{docId} {
      allow read: if isOwner() || (isMember() && request.auth.token.email == resource.data.email);
      allow write: if isOwner();
    }

    match /staff/{docId} {
      allow read: if isOwner();
      allow write: if isOwner();
    }

    match /equipment/{docId} {
      allow read: if isLoggedIn();
      allow write: if isOwner();
    }

    match /supplements/{docId} {
      allow read: if isLoggedIn();
      allow write: if isOwner();
    }

    match /supplement_sales/{docId} {
      allow read: if isOwner();
      allow write: if isOwner();
    }

    match /gym_settings/{docId} {
      allow read: if isLoggedIn();
      allow write: if isOwner();
    }

    // ─── ZUMBA COLLECTIONS ──────────────────────────────────────
    match /zumba_members/{docId} {
      allow read: if isOwner() || (isZumba() && request.auth.token.email == resource.data.email);
      allow write: if isOwner();
    }

    match /zumba_attendance/{docId} {
      allow read: if isOwner() || isZumba();
      allow write: if isOwner();
    }

    match /zumba_fees/{docId} {
      allow read: if isOwner() || (isZumba() && request.auth.token.email == resource.data.email);
      allow write: if isOwner();
    }

    match /zumba_settings/{docId} {
      allow read: if isLoggedIn();
      allow write: if isOwner();
    }

    // ─── DENY ALL ELSE ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
